---
import { navi } from '@data/naviConfig';
const { title, canonicalURL } = Astro.props;

// Determine if we're on the home page
const isHomePage = Astro.url?.pathname === '/';
---

<link rel="icon" type="image/png" href="/favicons/favicon-96x96.png" sizes="96x96" />
<link rel="icon" type="image/svg+xml" href="/favicons/favicon.svg" />
<link rel="shortcut icon" href="/favicons/favicon.ico" />
<link rel="apple-touch-icon" sizes="180x180" href="/favicons/apple-touch-icon.png" />
<meta name="apple-mobile-web-app-title" content={navi.config.client} />
<link rel="manifest" href="/site.webmanifest" />

<title>
  {
    isHomePage
      ? `${navi.config.client} pattern library`
      : `${title} - ${navi.config.client} pattern library`
  }
</title>

<link rel="canonical" href={canonicalURL} />
