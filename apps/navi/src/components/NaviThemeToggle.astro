<style is:global>
  .navi-theme-toggle {
    display: block;
    padding: 0.625rem;
    background-color: transparent;
    border: 1px solid #2b2b2b;
    color: #2b2b2b;
  }

  .navi-theme-toggle:hover {
    background-color: #2b2b2b;
    color: #fefbf6;
  }

  .navi-theme-toggle svg {
    width: auto;
    height: 1rem;
  }

  .navi-theme-toggle .visually-hidden {
    border: 0;
    clip: rect(0 0 0 0);
    height: 0;
    margin: 0;
    overflow: hidden;
    padding: 0;
    position: absolute;
    width: 1px;
    white-space: nowrap;
  }
</style>

<script>
  class NaviThemeToggle extends HTMLElement {
    connectedCallback() {
      const storageKey = 'user-color-scheme';
      const link = this.querySelector<HTMLLinkElement>('a');
      const text = this.querySelector<HTMLElement>('.text');
      const icon = this.querySelector<HTMLElement>('.icon');
      const sunIcon = icon?.querySelector<SVGElement>('#sun');
      const moonIcon = icon?.querySelector<SVGElement>('#moon');

      // Bail out if required elements are missing.
      if (!link || !text || !sunIcon || !moonIcon) return;

      // Grab the initial theme preference.
      let theme = localStorage.getItem(storageKey) || 'light';

      // Updates the NaviThemeToggle UI and optionally apply the light/dark theme attribute.
      const updateUI = (newTheme) => {
        theme = newTheme;

        // Determine if we are inside an iframe or viewing the standalone fullscreen page.
        const isInsideIframe = window.self !== window.top;
        const isFullscreenPage = window.location.pathname.includes('/fullscreen');

        // Only apply the 'data-user-theme' attribute component preview context, not the Navi pattern library itself.
        if (isInsideIframe || isFullscreenPage) {
          document.documentElement.setAttribute('data-user-theme', newTheme);
        }

        // Update the accessibility label.
        text.textContent = `Switch to ${newTheme === 'light' ? 'Dark' : 'Light'} Theme`;

        // Toggle visibility between sun and moon icons.
        if (newTheme === 'light') {
          sunIcon.style.display = 'none';
          moonIcon.style.display = 'block';
        } else {
          sunIcon.style.display = 'block';
          moonIcon.style.display = 'none';
        }
      };

      // Broadcasts the theme change to other parts of the library.
      const broadcastChange = (newTheme) => {
        // Determine if we need to talk 'up' to a parent or 'down' to children.
        const isInsideIframe = window.self !== window.top;

        if (isInsideIframe) {
          // If inside an iframe, notify the parent to sync other frames.
          window.parent.postMessage(
            { type: 'SET_THEME_TOGGLE', mode: newTheme },
            window.location.origin
          );
        } else {
          // If on the parent page, broadcast the change down to all NaviPreviewFrame embedded iframe(s).
          const previewFrames = document.querySelectorAll<HTMLIFrameElement>(
            '.navi-preview-frame iframe'
          );

          // Loop through all the preview frames and tell them to update page theme.
          previewFrames.forEach((frame) => {
            frame.contentWindow?.postMessage(
              { type: 'SET_THEME_TOGGLE', mode: newTheme },
              window.location.origin
            );
          });
        }
      };

      // Listen for messages from other frames to keep this in sync.
      window.addEventListener('message', (event) => {
        // Only allow messages from our own domain.
        if (event.origin !== window.location.origin) return;

        // Update UI when a light/dark theme toggle change is received.
        if (event.data.type === 'SET_THEME_TOGGLE') {
          updateUI(event.data.mode);
        }
      });

      // Handle user click interaction.
      link.addEventListener('click', (e) => {
        e.preventDefault();

        // Flip the theme.
        const nextTheme = theme === 'light' ? 'dark' : 'light';

        // Persist the choice throughout.
        localStorage.setItem(storageKey, nextTheme);
        updateUI(nextTheme);
        broadcastChange(nextTheme);
      });

      // Initialise on load.
      updateUI(theme);
    }
  }

  customElements.define('navi-theme-toggle', NaviThemeToggle);
</script>
