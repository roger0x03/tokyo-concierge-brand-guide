---
import NaviFullscreenLayout from '@layouts/NaviFullscreenLayout.astro';
import textLeading from '@repo/design-tokens/text-leading.json';
import { getValidEntries } from '@utils/validEntries';

// Leading
const textLeadingData = textLeading.leading || {};

// Filter out keys likes $type or $description
const textLeadingEntries = getValidEntries(textLeadingData);

// Set the page title.
const title = `Text leading`;
---

<NaviFullscreenLayout title={title} hideHeader={true} hideFooter={true}>
  <div class="flow" style="padding: 1.5rem;">
    {
      textLeadingEntries.length > 0 ? (
        textLeadingEntries.map(([name, data]: [string, any]) => {
          const formattedName = name.charAt(0).toUpperCase() + name.slice(1);
          const varName = `var(--leading-${name})`;
          const value = data.$value;

          return (
            <div style={`line-height: ${varName}; margin-block-end: 2rem;`}>
              <strong>
                {formattedName} (value: {value})
              </strong>
              <p>
                Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor
                incididunt ut labore et dolore magna aliqua.
              </p>
            </div>
          );
        })
      ) : (
        <p>No leading entries available.</p>
      )
    }
    <!-- {
      textLeadingData.map(({ varName, label, value }) => (
        <div style={`line-height: ${varName}; margin-block-end: 2rem;`}>
          <strong>
            {label} (value: {value})
          </strong>
          <p>
            Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor
            incididunt ut labore et dolore magna aliqua.
          </p>
        </div>
      ))
    } -->
  </div>
</NaviFullscreenLayout>
